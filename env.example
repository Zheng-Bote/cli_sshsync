# Example .env file for SSH Folder Sync

# rename it to ".env.example"

# You can specify custom paths for this file using the --env CLI parameter.

# Optional: Override the default log level (trace, debug, info, warn, err, critical)
# Default is 'info'.
LOG_LEVEL=info

# Format for user passwords: USER_<username>_PASSWORD=...
USER_admin_PASSWORD=super_secret_password
USER_deploy_PASSWORD=deploy_key_password

# Format for target directories on hosts: HOST_<hostname>_TARGETDIR=...
# Note: Ensure the hostname exactly matches the <target_host> command line parameter.
HOST_192.168.1.55_TARGETDIR=/home/admin/backup
HOST_myserver.local_TARGETDIR=/var/www/html
